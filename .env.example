# Copy to ".env" and fill in real values (see Supabase Dashboard → Project Settings → API).
# Used by: scripts/generate-config.js (anon URL + key) and `npm run dev:vercel` (all vars).

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# Server-only: Vercel project env + local `vercel dev`. Never put the service role in js/config.js.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CRON_SECRET=generate-a-long-random-string-for-bearer-auth

# Must match the admin email in admin.html (ALLOWED_ADMIN_EMAIL) — used by /api/admin-ping-health.
ADMIN_EMAIL=your-admin@example.com

# Local DB ping (npm run dev:ping) — same as Vercel /api/health upsert + health_ping_log.
